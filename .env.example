# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                    # development | production

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/iam_service

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                         # leave blank if no auth

# ── Session ───────────────────────────────────────────────
SESSION_SECRET=your_super_secret_session_key

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret
JWT_REFRESH_SECRET=your_refresh_token_secret

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001,http://localhost:4000

# ── Bootstrap First Admin ──────────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=admin@123
BOOTSTRAP_ADMIN_ENABLED=true

